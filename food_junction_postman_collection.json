                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "example": "employee"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered successfully"
